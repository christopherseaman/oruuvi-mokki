  "templating": {
    "list": []
  },
  "annotations": {
    "list": []
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Pressure rolling stddev \u2014 15s, 3-min, 5-min overlay (no thresholds: pick what looks clearest)",
      "datasource": {
        "type": "frser-sqlite-datasource",
        "uid": "oruuvi-sqlite"
      },
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 10
      },
      "fieldConfig": {
        "defaults": {
          "unit": "pressurepa",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "fillOpacity": 0,
            "lineWidth": 1
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "sd_15s_pa"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "#dc2626"
                }
              },
              {
                "id": "custom.lineWidth",
                "value": 1
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "sd_3min_pa"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "#1d4ed8"
                }
              },
              {
                "id": "custom.lineWidth",
                "value": 1.5
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "sd_5min_pa"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "#d97706"
                }
              },
              {
                "id": "custom.lineWidth",
                "value": 2
              }
            ]
          }
        ]
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "single"
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "frser-sqlite-datasource",
            "uid": "oruuvi-sqlite"
          },
          "queryType": "table",
          "rawQueryText": "SELECT epoch_ms AS time, 100.0 * SQRT(MAX(0.0, AVG(pressure_hpa*pressure_hpa) OVER w15  - AVG(pressure_hpa) OVER w15  * AVG(pressure_hpa) OVER w15))  AS sd_15s_pa, 100.0 * SQRT(MAX(0.0, AVG(pressure_hpa*pressure_hpa) OVER w180 - AVG(pressure_hpa) OVER w180 * AVG(pressure_hpa) OVER w180)) AS sd_3min_pa, 100.0 * SQRT(MAX(0.0, AVG(pressure_hpa*pressure_hpa) OVER w300 - AVG(pressure_hpa) OVER w300 * AVG(pressure_hpa) OVER w300)) AS sd_5min_pa FROM readings WHERE epoch_ms >= $__timeFrom - 300000 AND epoch_ms <= $__timeTo WINDOW w15  AS (ORDER BY epoch_ms RANGE BETWEEN  15000 PRECEDING AND CURRENT ROW), w180 AS (ORDER BY epoch_ms RANGE BETWEEN 180000 PRECEDING AND CURRENT ROW), w300 AS (ORDER BY epoch_ms RANGE BETWEEN 300000 PRECEDING AND CURRENT ROW) ORDER BY time",
          "queryText": "SELECT epoch_ms AS time, 100.0 * SQRT(MAX(0.0, AVG(pressure_hpa*pressure_hpa) OVER w15  - AVG(pressure_hpa) OVER w15  * AVG(pressure_hpa) OVER w15))  AS sd_15s_pa, 100.0 * SQRT(MAX(0.0, AVG(pressure_hpa*pressure_hpa) OVER w180 - AVG(pressure_hpa) OVER w180 * AVG(pressure_hpa) OVER w180)) AS sd_3min_pa, 100.0 * SQRT(MAX(0.0, AVG(pressure_hpa*pressure_hpa) OVER w300 - AVG(pressure_hpa) OVER w300 * AVG(pressure_hpa) OVER w300)) AS sd_5min_pa FROM readings WHERE epoch_ms >= $__timeFrom - 300000 AND epoch_ms <= $__timeTo WINDOW w15  AS (ORDER BY epoch_ms RANGE BETWEEN  15000 PRECEDING AND CURRENT ROW), w180 AS (ORDER BY epoch_ms RANGE BETWEEN 180000 PRECEDING AND CURRENT ROW), w300 AS (ORDER BY epoch_ms RANGE BETWEEN 300000 PRECEDING AND CURRENT ROW) ORDER BY time"
        }
      ]
    },

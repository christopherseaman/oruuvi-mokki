                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "#d97706"
                }
              },
              {
                "id": "custom.lineWidth",
                "value": 2
              }
            ]
          }
        ]
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "single"
        }
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "frser-sqlite-datasource",
            "uid": "oruuvi-sqlite"
          },
          "queryType": "table",
          "rawQueryText": "SELECT epoch_ms AS time, pressure_hpa AS raw_hpa, AVG(pressure_hpa) OVER (ORDER BY epoch_ms RANGE BETWEEN 300000 PRECEDING AND CURRENT ROW) AS trend_5min_hpa FROM readings WHERE epoch_ms >= $__timeFrom - 300000 AND epoch_ms <= $__timeTo ORDER BY time",
          "queryText": "SELECT epoch_ms AS time, pressure_hpa AS raw_hpa, AVG(pressure_hpa) OVER (ORDER BY epoch_ms RANGE BETWEEN 300000 PRECEDING AND CURRENT ROW) AS trend_5min_hpa FROM readings WHERE epoch_ms >= $__timeFrom - 300000 AND epoch_ms <= $__timeTo ORDER BY time"
        }
      ]
    },
